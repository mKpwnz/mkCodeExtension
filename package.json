{
    "name": "mk-coding-extension",
    "displayName": "mK Coding Extension",
    "description": "A bundled mK coding experience with theme, icons and more.",
    "version": "0.1.8",
    "publisher": "mKpwnz",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/mKpwnz/mkCodeExtension.git"
    },
    "categories": [
        "Themes",
        "Other"
    ],
    "keywords": [
        "theme",
        "icons",
        "product-icons",
        "file-icons",
        "better-comments",
        "error-lens",
        "path-intellisense",
        "commit-message",
        "mk"
    ],
    "engines": {
        "vscode": "^1.90.0"
    },
    "extensionKind": [
        "ui",
        "workspace"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "themes": [
            {
                "label": "mK Theme Dark",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkColorTheme.json"
            },
            {
                "label": "mK Theme Dark Balanced Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkBalancedCodeTheme.json"
            },
            {
                "label": "mK Theme Dark Copilot Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkCopilotCodeTheme.json"
            },
            {
                "label": "mK Theme Dark One Dark Pro Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkOneDarkProCodeTheme.json"
            },
            {
                "label": "mK Theme Dark Atom One Dark Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkAtomOneDarkCodeTheme.json"
            },
            {
                "label": "mK Theme Dark Dracula Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkDraculaCodeTheme.json"
            },
            {
                "label": "mK Theme Dark VS Code 2026 Dark Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkVsCode2026DarkCodeTheme.json"
            },
            {
                "label": "mK Theme Dark VS Code Dark+ Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkVsCodeDarkPlusCodeTheme.json"
            },
            {
                "label": "mK Theme Dark VS Code Dark Modern Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkVsCodeDarkModernCodeTheme.json"
            },
            {
                "label": "mK Theme Dark VS Code Visual Studio Dark Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkVsCodeVisualStudioDarkCodeTheme.json"
            },
            {
                "label": "mK Theme Dark VS Code High Contrast Code",
                "uiTheme": "vs-dark",
                "path": "./assets/themes/mkThemeDarkVsCodeHighContrastCodeTheme.json"
            }
        ],
        "productIconThemes": [
            {
                "id": "mk-product-icons",
                "label": "mK Product Icons",
                "path": "./assets/productIcons/mkProductIcons.json"
            }
        ],
        "iconThemes": [
            {
                "id": "mk-file-icons",
                "label": "mK File Icons",
                "path": "./assets/fileIcons/mkFileIcons.json"
            }
        ],
        "commands": [
            {
                "command": "mkErrorLens.copyProblemMessage",
                "title": "Copy Problem Message",
                "category": "mK Error Lens"
            },
            {
                "command": "mkCommitMessageEditor.openEditor",
                "title": "Open Commit Message Editor",
                "category": "mK Commit Message Editor",
                "icon": "$(edit)"
            },
            {
                "command": "mkCommitMessageEditor.loadTemplate",
                "title": "Load Commit Message Template",
                "category": "mK Commit Message Editor"
            },
            {
                "command": "mkCommitMessageEditor.copyFromScmInputBox",
                "title": "Copy Text From SCM Input Box",
                "category": "mK Commit Message Editor"
            }
        ],
        "menus": {
            "scm/title": [
                {
                    "command": "mkCommitMessageEditor.openEditor",
                    "group": "navigation@1",
                    "when": "scmProvider == git"
                }
            ]
        },
        "configuration": [
            {
                "type": "object",
                "title": "mK Theme",
                "properties": {
                    "mkTheme.highlightPreset": {
                        "type": "string",
                        "order": 1,
                        "default": "lime",
                        "enum": [
                            "azure",
                            "graphite",
                            "silver",
                            "green",
                            "lime",
                            "amber",
                            "red",
                            "coral",
                            "yellow",
                            "cyan",
                            "violet",
                            "magenta",
                            "pink",
                            "custom"
                        ],
                        "enumItemLabels": [
                            "Azure (#0792f1)",
                            "Graphite (#323239)",
                            "Silver (#efeff1)",
                            "Green (#17bf6b)",
                            "Lime (#a1fb1a)",
                            "Amber (#ffc632)",
                            "Red (#e91916)",
                            "Coral (#fa7342)",
                            "Yellow (#fbd91a)",
                            "Cyan (#1acafa)",
                            "Violet (#8270fa)",
                            "Magenta (#da5dfa)",
                            "Pink (#fb477e)",
                            "Custom"
                        ],
                        "enumDescriptions": [
                            "Use #0792f1 for active UI highlights.",
                            "Use #323239 for active UI highlights.",
                            "Use #efeff1 for active UI highlights.",
                            "Use #17bf6b for active UI highlights.",
                            "Use #a1fb1a for active UI highlights.",
                            "Use #ffc632 for active UI highlights.",
                            "Use #e91916 for active UI highlights.",
                            "Use #fa7342 for active UI highlights.",
                            "Use #fbd91a for active UI highlights.",
                            "Use #1acafa for active UI highlights.",
                            "Use #8270fa for active UI highlights.",
                            "Use #da5dfa for active UI highlights.",
                            "Use #fb477e for active UI highlights.",
                            "Use the custom hex color configured below."
                        ],
                        "description": "Predefined highlight color used for mK Theme Dark accents."
                    },
                    "mkTheme.highlightColor": {
                        "type": "string",
                        "order": 2,
                        "default": "#a1fb1a",
                        "format": "color-hex",
                        "pattern": "^#[0-9a-fA-F]{6}$",
                        "markdownDescription": "Custom highlight color used when `mK Theme: Highlight Preset` is `custom`. Use a six-digit hex color such as `#a1fb1a`; VS Code can show this as a color swatch in supported settings views."
                    }
                }
            },
            {
                "type": "object",
                "title": "mK Indent Rainbow",
                "properties": {
                    "mkIndentRainbow.includedLanguages": {
                        "type": "array",
                        "order": 10,
                        "items": {
                            "type": "string"
                        },
                        "default": [],
                        "description": "Languages where mK Indent Rainbow should be enabled. Empty means all languages except excluded languages."
                    },
                    "mkIndentRainbow.excludedLanguages": {
                        "type": "array",
                        "order": 11,
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "plaintext"
                        ],
                        "description": "Languages where mK Indent Rainbow should be disabled."
                    },
                    "mkIndentRainbow.ignoreErrorLanguages": {
                        "type": "array",
                        "order": 12,
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "markdown"
                        ],
                        "description": "Languages where indentation error detection is skipped. Use * to disable errors for all languages."
                    },
                    "mkIndentRainbow.updateDelay": {
                        "type": "integer",
                        "order": 13,
                        "default": 100,
                        "minimum": 0,
                        "maximum": 2000,
                        "description": "Delay in milliseconds before indentation decorations update."
                    },
                    "mkIndentRainbow.errorColor": {
                        "type": "string",
                        "order": 14,
                        "default": "rgba(188,63,60,0.38)",
                        "description": "Decoration color for indentation errors."
                    },
                    "mkIndentRainbow.tabmixColor": {
                        "type": "string",
                        "order": 15,
                        "default": "rgba(214,116,185,0.32)",
                        "description": "Decoration color for mixed tabs and spaces. Empty disables this decoration."
                    },
                    "mkIndentRainbow.ignoreLinePatterns": {
                        "type": "array",
                        "order": 16,
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "/[ \\t]* [*]/g",
                            "/[ \\t]+[/]{2}/g"
                        ],
                        "description": "Regular expressions for lines that should skip indentation error highlighting."
                    },
                    "mkIndentRainbow.colors": {
                        "type": "array",
                        "order": 17,
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "rgba(73,151,250,0.08)",
                            "rgba(18,184,162,0.08)",
                            "rgba(224,153,45,0.08)",
                            "rgba(134,134,209,0.08)"
                        ],
                        "description": "Indentation colors cycled by indent level."
                    },
                    "mkIndentRainbow.colorOnWhiteSpaceOnly": {
                        "type": "boolean",
                        "order": 18,
                        "default": false,
                        "description": "Only color actual whitespace when an indent segment is incomplete."
                    },
                    "mkIndentRainbow.indicatorStyle": {
                        "type": "string",
                        "order": 19,
                        "default": "classic",
                        "enum": [
                            "classic",
                            "light"
                        ],
                        "description": "Classic uses a subtle full indent background. Light uses a thin left border."
                    },
                    "mkIndentRainbow.lightIndicatorStyleLineWidth": {
                        "type": "number",
                        "order": 20,
                        "default": 1,
                        "minimum": 1,
                        "maximum": 8,
                        "description": "Line width for light indicator style."
                    },
                    "mkIndentRainbow.maxLineCount": {
                        "type": "integer",
                        "order": 21,
                        "default": 20000,
                        "minimum": 100,
                        "maximum": 100000,
                        "description": "Maximum number of document lines decorated per update."
                    }
                }
            },
            {
                "type": "object",
                "title": "mK Better Comments",
                "properties": {
                    "mkBetterComments.enabled": {
                        "type": "boolean",
                        "order": 30,
                        "default": true,
                        "description": "Enable mK Better Comments highlighting."
                    },
                    "mkBetterComments.multilineComments": {
                        "type": "boolean",
                        "order": 31,
                        "default": true,
                        "description": "Highlight tags inside multiline comments."
                    },
                    "mkBetterComments.highlightPlainText": {
                        "type": "boolean",
                        "order": 32,
                        "default": false,
                        "description": "Highlight tags in plain text files and non-comment text."
                    },
                    "mkBetterComments.maxLineCount": {
                        "type": "integer",
                        "order": 33,
                        "default": 20000,
                        "minimum": 100,
                        "maximum": 100000,
                        "description": "Maximum number of document lines scanned for comment tags."
                    },
                    "mkBetterComments.tags": {
                        "type": "array",
                        "order": 34,
                        "description": "Comment tags and styles used by mK Better Comments.",
                        "default": [
                            {
                                "tag": "!",
                                "color": "#ff6464",
                                "strikethrough": false,
                                "underline": false,
                                "backgroundColor": "transparent",
                                "bold": false,
                                "italic": false
                            },
                            {
                                "tag": "?",
                                "color": "#1acafa",
                                "strikethrough": false,
                                "underline": false,
                                "backgroundColor": "transparent",
                                "bold": false,
                                "italic": false
                            },
                            {
                                "tag": "//",
                                "color": "#6f747c",
                                "strikethrough": true,
                                "underline": false,
                                "backgroundColor": "transparent",
                                "bold": false,
                                "italic": false
                            },
                            {
                                "tag": "todo",
                                "color": "#ffc632",
                                "strikethrough": false,
                                "underline": false,
                                "backgroundColor": "transparent",
                                "bold": false,
                                "italic": false
                            },
                            {
                                "tag": "*",
                                "color": "#17bf6b",
                                "strikethrough": false,
                                "underline": false,
                                "backgroundColor": "transparent",
                                "bold": false,
                                "italic": false
                            }
                        ]
                    }
                }
            },
            {
                "type": "object",
                "title": "mK Error Lens",
                "properties": {
                    "mkErrorLens.enabled": {
                        "type": "boolean",
                        "order": 40,
                        "default": true,
                        "description": "Enable inline diagnostic highlighting."
                    },
                    "mkErrorLens.enabledDiagnosticLevels": {
                        "type": "array",
                        "order": 41,
                        "items": {
                            "type": "string",
                            "enum": [
                                "error",
                                "warning",
                                "info",
                                "hint"
                            ]
                        },
                        "uniqueItems": true,
                        "default": [
                            "error",
                            "warning",
                            "info"
                        ],
                        "description": "Diagnostic severities shown inline."
                    },
                    "mkErrorLens.messageEnabled": {
                        "type": "boolean",
                        "order": 42,
                        "default": true,
                        "description": "Show diagnostic messages after the affected line."
                    },
                    "mkErrorLens.problemRangeDecorationEnabled": {
                        "type": "boolean",
                        "order": 43,
                        "default": false,
                        "description": "Highlight the diagnostic range."
                    },
                    "mkErrorLens.messageTemplate": {
                        "type": "string",
                        "order": 44,
                        "default": "$message",
                        "description": "Inline diagnostic template. Supports $message, $source and $code."
                    },
                    "mkErrorLens.messageMaxChars": {
                        "type": "integer",
                        "order": 45,
                        "default": 500,
                        "minimum": 0,
                        "maximum": 10000,
                        "description": "Maximum number of characters per inline diagnostic message."
                    },
                    "mkErrorLens.removeLinebreaks": {
                        "type": "boolean",
                        "order": 46,
                        "default": true,
                        "description": "Replace line breaks in diagnostic messages with spaces."
                    }
                }
            },
            {
                "type": "object",
                "title": "mK Path Intellisense",
                "properties": {
                    "mkPathIntellisense.extensionOnImport": {
                        "type": "boolean",
                        "order": 50,
                        "default": false,
                        "description": "Include file extensions in import completions."
                    },
                    "mkPathIntellisense.mappings": {
                        "type": "object",
                        "order": 51,
                        "default": {
                            "@": "${workspaceFolder}/src"
                        },
                        "description": "Path aliases. Values can use ${workspaceFolder}."
                    },
                    "mkPathIntellisense.showHiddenFiles": {
                        "type": "boolean",
                        "order": 52,
                        "default": false,
                        "description": "Show hidden files in path completions."
                    },
                    "mkPathIntellisense.autoSlashAfterDirectory": {
                        "type": "boolean",
                        "order": 53,
                        "default": false,
                        "description": "Insert a trailing slash after directory completions."
                    }
                }
            },
            {
                "type": "object",
                "title": "mK Commit Message Editor",
                "properties": {
                    "mkCommitMessageEditor.staticTemplate": {
                        "type": "array",
                        "order": 60,
                        "items": {
                            "type": "string"
                        },
                        "default": [
                            "feat: Short description",
                            "",
                            "Message body",
                            "",
                            "Message footer"
                        ],
                        "description": "Template inserted into the SCM input box."
                    },
                    "mkCommitMessageEditor.reduceEmptyLines": {
                        "type": "boolean",
                        "order": 61,
                        "default": true,
                        "description": "Collapse more than two consecutive empty lines."
                    },
                    "mkCommitMessageEditor.saveAndClose": {
                        "type": "boolean",
                        "order": 62,
                        "default": false,
                        "description": "Close the editor webview after saving to the SCM input box."
                    }
                }
            },
            {
                "type": "object",
                "title": "mK Explorer",
                "properties": {
                    "mkExplorer.indent": {
                        "type": "integer",
                        "order": 70,
                        "default": 16,
                        "minimum": 4,
                        "maximum": 40,
                        "description": "Explorer tree indentation in pixels. Applied to VS Code's Workbench: Tree Indent setting."
                    },
                    "mkExplorer.renderIndentGuides": {
                        "type": "string",
                        "order": 71,
                        "default": "always",
                        "enum": [
                            "none",
                            "onHover",
                            "always"
                        ],
                        "description": "Explorer tree indent guide visibility. Applied to VS Code's Workbench: Tree Render Indent Guides setting."
                    }
                }
            }
        ]
    },
    "scripts": {
        "theme:generate": "bun tools/generateThemes.ts",
        "build": "bun run theme:generate && bunx tsc -p tsconfig.json && bunx tsc-alias -p tsconfig.json",
        "check": "bun run typecheck && bun run typecheck:tools && bun run lint && bun run validate",
        "typecheck": "bunx tsc --noEmit -p tsconfig.json",
        "typecheck:tools": "bunx tsc --noEmit -p tsconfig.scripts.json",
        "lint": "bunx biome check .",
        "format": "bunx biome format --write .",
        "validate": "bun tools/validateExtension.ts",
        "import:elegant": "bun tools/importElegantTheme.ts",
        "import:code-themes": "bun tools/importCodeThemes.ts",
        "import:fluent": "bun tools/importFluentIcons.ts",
        "import:material": "bun tools/importMaterialIcons.ts",
        "import:all": "bun run import:elegant && bun run import:code-themes && bun run theme:generate && bun run import:fluent && bun run import:material",
        "package": "bun run theme:generate && bun tools/packageExtension.ts",
        "publish": "bunx @vscode/vsce publish"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.1",
        "@types/node": "^24.0.0",
        "@types/vscode": "^1.90.0",
        "@vscode/vsce": "^3.6.4",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.8.3"
    }
}
