        },
        {
            "scope": [
                "support.type.vendored.property-name",
                "support.type.property-name",
                "source.css variable",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#d4d4d4"
            }
        },
        {
            "scope": "keyword",
            "settings": {
                "foreground": "#569cd6"
            }
        },
        {
            "scope": "keyword.control",
            "settings": {
                "foreground": "#569cd6"
            }
        },
        {
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#d4d4d4"
