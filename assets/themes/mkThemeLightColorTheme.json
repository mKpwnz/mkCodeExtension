    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#4b5666",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["string", "constant.other.symbol"],
            "settings": {
                "foreground": "#007d51"
            }
        },
        {
            "scope": ["constant.numeric", "constant.language", "support.constant"],
            "settings": {
                "foreground": "#c17000"
            }
        },
        {
            "scope": ["keyword", "storage", "storage.type"],
            "settings": {
                "foreground": "#b87d25"
            }
        },
        {
            "scope": ["entity.name.function", "support.function", "meta.function-call"],
            "settings": {
                "foreground": "#3c7ccd"
            }
        },
        {
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": {
                "foreground": "#0f9785"
            }
        },
        {
            "scope": ["variable", "variable.other.readwrite"],
            "settings": {
                "foreground": "#6e6eab"
            }
        },
        {
            "scope": ["variable.parameter", "meta.function.parameters"],
            "settings": {
                "foreground": "#108c9d"
            }
        },
        {
            "scope": ["variable.other.property", "support.variable.property"],
            "settings": {
                "foreground": "#89949f"
            }
        },
        {
            "scope": ["entity.other.attribute-name", "meta.decorator"],
            "settings": {
                "foreground": "#b87d25"
            }
        },
        {
            "scope": ["entity.name.tag", "support.type.property-name"],
            "settings": {
                "foreground": "#3c7ccd"
            }
        },
        {
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#9a3431",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticTokenColors": {
        "class": "#0f9785",
        "enum": "#0f9785",
        "function": "#3c7ccd",
        "interface": "#0f9785",
        "keyword": "#b87d25",
        "method": "#3c7ccd",
        "namespace": "#b87d25",
        "parameter": "#108c9d",
        "property": "#89949f",
        "string": "#007d51",
        "type": "#0f9785",
        "typeParameter": "#b87d25",
        "variable": "#5f5f99"
    }
