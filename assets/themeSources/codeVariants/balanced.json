{
    "label": "mK Theme Dark Balanced Code",
    "outputPath": "mkThemeDarkBalancedCodeTheme.json",
    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#6f747c",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["string", "constant.other.symbol"],
            "settings": {
                "foreground": "#17bf6b"
            }
        },
        {
            "scope": ["constant.numeric", "constant.language", "support.constant"],
            "settings": {
                "foreground": "#ffc632"
            }
        },
        {
            "scope": ["keyword", "storage", "storage.type"],
            "settings": {
                "foreground": "#fb477e"
            }
        },
        {
            "scope": ["entity.name.function", "support.function", "meta.function-call"],
            "settings": {
                "foreground": "#1acafa"
            }
        },
        {
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": {
                "foreground": "#8270fa"
            }
        },
        {
            "scope": ["variable", "variable.other.readwrite"],
            "settings": {
                "foreground": "#efeff1"
            }
        },
        {
            "scope": ["variable.parameter", "meta.function.parameters"],
            "settings": {
                "foreground": "#fa7342"
            }
        },
        {
            "scope": ["variable.other.property", "support.variable.property"],
            "settings": {
                "foreground": "#a7b4c2"
            }
        },
        {
            "scope": ["entity.other.attribute-name", "meta.decorator"],
            "settings": {
                "foreground": "#da5dfa"
            }
        },
        {
            "scope": ["entity.name.tag", "support.type.property-name"],
            "settings": {
                "foreground": "#0792f1"
            }
        },
        {
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#e91916",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticTokenColors": {
        "class": "#8270fa",
        "enum": "#8270fa",
        "function": "#1acafa",
        "interface": "#8270fa",
        "keyword": "#fb477e",
        "method": "#1acafa",
        "namespace": "#da5dfa",
        "parameter": "#fa7342",
        "property": "#a7b4c2",
        "string": "#17bf6b",
        "type": "#8270fa",
        "typeParameter": "#da5dfa",
        "variable": "#efeff1"
    }
}
