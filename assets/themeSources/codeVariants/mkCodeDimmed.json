{
    "label": "mK Code Dimmed",
    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": {
                "foreground": "#6b7889",
                "fontStyle": "italic"
            }
        },
        {
            "scope": ["string", "constant.other.symbol"],
            "settings": {
                "foreground": "#1aa373"
            }
        },
        {
            "scope": ["constant.numeric", "constant.language", "support.constant"],
            "settings": {
                "foreground": "#ed941a"
            }
        },
        {
            "scope": ["keyword", "storage", "storage.type"],
            "settings": {
                "foreground": "#e3a342"
            }
        },
        {
            "scope": ["entity.name.function", "support.function", "meta.function-call"],
            "settings": {
                "foreground": "#5ba1fb"
            }
        },
        {
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": {
                "foreground": "#2abfab"
            }
        },
        {
            "scope": ["variable", "variable.other.readwrite"],
            "settings": {
                "foreground": "#9292d6"
            }
        },
        {
            "scope": ["variable.parameter", "meta.function.parameters"],
            "settings": {
                "foreground": "#2bb3c6"
            }
        },
        {
            "scope": ["variable.other.property", "support.variable.property"],
            "settings": {
                "foreground": "#b0bcc8"
            }
        },
        {
            "scope": ["entity.other.attribute-name", "meta.decorator"],
            "settings": {
                "foreground": "#e3a342"
            }
        },
        {
            "scope": ["entity.name.tag", "support.type.property-name"],
            "settings": {
                "foreground": "#5ba1fb"
            }
        },
        {
            "scope": ["invalid", "invalid.illegal"],
            "settings": {
                "foreground": "#c35250",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticTokenColors": {
        "class": "#2abfab",
        "enum": "#2abfab",
        "function": "#5ba1fb",
        "interface": "#2abfab",
        "keyword": "#e3a342",
        "method": "#5ba1fb",
        "namespace": "#e3a342",
        "parameter": "#2bb3c6",
        "property": "#b0bcc8",
        "string": "#1aa373",
        "type": "#2abfab",
        "typeParameter": "#e3a342",
        "variable": "#9292d6"
    }
}
