{
    "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always"
        }
    },
    "json": {
        "formatter": {
            "enabled": true
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "files": {
        "includes": ["**", "!.cache", "!dist", "!node_modules", "!*.vsix", "!assets/webviews"]
    }
}
