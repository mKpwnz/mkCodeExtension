{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "jsx": "react-jsx",
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "types": ["react", "react-dom"],
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": ["**/*.d.ts", "**/*.ts", "**/*.tsx"]
}
